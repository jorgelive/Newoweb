{% extends '@SonataAdmin/CRUD/base_show.html.twig' %}

{% block title %}
    {{admin.toString(object)}}
{% endblock %}

{% block stylesheets %}
    {{ parent() }}

    <style>

        div.encabezado td {white-space: normal !important;}
        body > div.wrapper > header > nav > div.navbar-custom-menu > ul > li > a { background-color: white; }
        body > div > header > nav > div.navbar-left > div > ol > li.active {max-width: 250px; white-space: nowrap;}

        @media print
        {
            .locale_switcher {display: none !important;}
            .tab-content > .tab-pane {display: block !important; opacity: 1 !important; visibility: visible !important;}
        }

        @media (max-width:768px){
            .navbar-header{display: none;}
            .navbar{min-height:initial;}
            .navbar-default .navbar-nav>li>a{padding-top: 0; padding-bottom: 0; }
        }

        .nav-tabs>li>a {padding: 7px 15px;}
        .nav-tabs-custom>.nav-tabs>li {border-top-width: 6px;}
        .nav-tabs-custom>.nav-tabs>li.active {border-color: {{ colores.verde_claro }};}
        .tab-icon{margin-right: 5px;}
        .nav-tabs-custom>.tab-content {padding: 0;}
        .nav-tabs-custom>.nav-tabs>li>a {padding: 5px;}
        .nav-tabs-custom>.nav-tabs>li>a>span{font-size: 1.1em;}

        {# estilos varios #}
        h4 { font-size: 16px; }
        .margin-top-10 { margin-top: 10px; }
        .margin-bottom-10 { margin-bottom: 10px; }
        .titulo-verde { font-weight: bold; color: {{ colores.verde_oscuro }}; }
        .row-line { border-bottom: 3px #ccc solid; }

    </style>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    <script src="{{ asset('/app/ckeditor/ckeditor.js') }}"></script>

    <script type="text/javascript">
        (function ($) {

            // ============================
            //  CKEditor helpers (Vista Show)
            // ============================
            const editors = new Map();

            /**
             * Retorna la configuración base para las instancias de CKEditor 5.
             * Habilita el soporte para etiquetas de imágenes y configura la barra de herramientas.
             *
             * @returns {Object} Objeto de configuración nativo de CKEditor.
             */
            function getCkeditorConfigBase() {
                return {
                    toolbar: {
                        shouldNotGroupWhenFull: true
                    },
                    htmlSupport: {
                        allow: [
                            { name: 'img', classes: true, attributes: true, styles: true }
                        ]
                    },
                    ui: {
                        viewportOffset: { top: 30 }
                    }
                };
            }

            /**
             * Inicializa las instancias de CKEditor en los elementos <textarea> que posean
             * las clases `.ckeditor` (editable) o `.ckeditorread` (solo lectura).
             * Previene la reinicialización mediante la clase de control `.ckrendered`.
             *
             * @param {HTMLElement|Document} scope El contexto del DOM donde se buscarán los elementos.
             */
            function initCkEditors(scope) {
                var $scope = scope ? $(scope) : $(document);

                // Instancias Editables (ej: para modales de envío de correos)
                $scope.find('.ckeditor').each(function () {
                    var $textarea = $(this);
                    if ($textarea.hasClass('ckrendered')) {
                        return;
                    }

                    var config = getCkeditorConfigBase();

                    ClassicEditor.create(this, config).then(editor => {
                        editors.set(editor.id, editor);
                    }).catch(error => {
                        // console.error(error);
                    });

                    $textarea.addClass('ckrendered');
                });

                // Instancias de Solo Lectura (ej: para mostrar contenido HTML formateado sin permitir edición)
                $scope.find('.ckeditorread').each(function () {
                    var $textarea = $(this);
                    if ($textarea.hasClass('ckrendered')) {
                        return;
                    }

                    var configReadOnly = getCkeditorConfigBase();
                    configReadOnly.readOnly = true;

                    ClassicEditor.create(this, configReadOnly).then(editor => {
                        editor.enableReadOnlyMode('oweb-readonly-feature');
                    }).catch(error => {
                        // console.error(error);
                    });

                    $textarea.addClass('ckrendered');
                });
            }

            // ============================
            //  LISTENERS NATIVOS
            // ============================

            document.addEventListener('DOMContentLoaded', function () {
                initCkEditors(document);
            });

            // Permite inicializar editores si se inyecta HTML dinámicamente en la vista show (ej. llamadas AJAX)
            document.addEventListener('oweb.add_element', function (ev) {
                var target = ev.target || document;
                initCkEditors(target);
            });

            // Exponer helpers globales para accesibilidad externa
            window.ckEditorsMap  = editors;
            window.initCkEditors = initCkEditors;

        })(jQuery);
    </script>
{% endblock %}